generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// ============================================================
// BETTER AUTH CORE MODELS
// ============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions        Session[]
  accounts        Account[]
  members         Member[]
  invitations     Invitation[]
  auditLogs       AuditLog[]
  aiConversations AIConversation[]
  taskAssignments TaskAssignment[]
  timeEntries     TimeEntry[]
  comments        Comment[]
  sentMessages    Message[]
  projectMembers  ProjectMember[]

  @@map("users")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  activeOrganizationId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}

// ============================================================
// BETTER AUTH ORGANIZATION PLUGIN MODELS
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  // Extended fields
  website      String?
  email        String?
  phone        String?
  address      Json?
  primaryColor String?
  accentColor  String?
  customDomain String?
  timezone     String  @default("America/New_York")
  currency     String  @default("USD")
  language     String  @default("en")
  plan         Plan    @default(FREE)
  planExpiresAt DateTime?
  stripeCustomerId String?
  settings     Json?

  members     Member[]
  invitations Invitation[]

  // Business relations
  clients        Client[]
  contacts       Contact[]
  leads          Lead[]
  invoices       Invoice[]
  estimates      Estimate[]
  payments       Payment[]
  projects       Project[]
  tasks          Task[]
  timeEntries    TimeEntry[]
  events         Event[]
  bookingPages   BookingPage[]
  threads        Thread[]
  emailAccounts  EmailAccount[]
  documents      Document[]
  files          File[]
  contracts      Contract[]
  webhooks       Webhook[]
  integrations   Integration[]
  auditLogs      AuditLog[]
  tags           Tag[]

  @@map("organizations")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member") // owner | admin | manager | member | client
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("members")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String   @default("pending") // pending | accepted | rejected | cancelled
  expiresAt      DateTime
  inviterId      String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================================
// TAGS
// ============================================================

model Tag {
  id             String @id @default(cuid())
  organizationId String
  name           String
  color          String @default("#6366f1")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clients      ClientTag[]
  leads        LeadTag[]
  tasks        TaskTag[]

  @@unique([organizationId, name])
  @@map("tags")
}

// ============================================================
// CRM: CLIENTS, CONTACTS, LEADS
// ============================================================

model Client {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  website        String?
  address        Json?
  avatar         String?
  industry       String?
  notes          String?      @db.Text
  status         ClientStatus @default(ACTIVE)
  portalEnabled  Boolean      @default(false)
  currency       String?
  taxId          String?
  paymentTerms   Int?         @default(30)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  invoices     Invoice[]
  estimates    Estimate[]
  projects     Project[]
  events       Event[]
  threads      Thread[]
  files        File[]
  contracts    Contract[]
  activities   ClientActivity[]
  tags         ClientTag[]

  @@index([organizationId])
  @@map("clients")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  ARCHIVED
}

model ClientTag {
  clientId String
  tagId    String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@map("client_tags")
}

model ClientActivity {
  id        String             @id @default(cuid())
  clientId  String
  type      ClientActivityType
  title     String
  body      String?            @db.Text
  metadata  Json?
  createdAt DateTime           @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_activities")
}

enum ClientActivityType {
  NOTE
  EMAIL
  CALL
  MEETING
  INVOICE
  PAYMENT
  CONTRACT
  FILE
  OTHER
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  firstName      String
  lastName       String
  email          String?
  phone          String?
  jobTitle       String?
  isPrimary      Boolean  @default(false)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("contacts")
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  company        String?
  source         String?
  status         LeadStatus @default(NEW)
  stage          String?
  value          Decimal?   @db.Decimal(12, 2)
  notes          String?    @db.Text
  assignedTo     String?
  closedAt       DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities   LeadActivity[]
  tags         LeadTag[]

  @@index([organizationId])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  title     String
  body      String?  @db.Text
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_activities")
}

model LeadTag {
  leadId String
  tagId  String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("lead_tags")
}

// ============================================================
// BILLING
// ============================================================

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String?
  number         String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  paidAt         DateTime?
  subtotal       Decimal       @db.Decimal(12, 2) @default(0)
  taxRate        Decimal       @db.Decimal(5, 2) @default(0)
  taxAmount      Decimal       @db.Decimal(12, 2) @default(0)
  discount       Decimal       @db.Decimal(12, 2) @default(0)
  total          Decimal       @db.Decimal(12, 2) @default(0)
  amountPaid     Decimal       @db.Decimal(12, 2) @default(0)
  amountDue      Decimal       @db.Decimal(12, 2) @default(0)
  currency       String        @default("USD")
  notes          String?       @db.Text
  terms          String?       @db.Text
  footer         String?       @db.Text
  stripePaymentIntentId String?
  stripeInvoiceId       String?
  recurringId    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  payments     Payment[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  VOID
  UNCOLLECTIBLE
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 2) @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  taxable     Boolean @default(true)
  order       Int     @default(0)
  timeEntryId String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Estimate {
  id             String         @id @default(cuid())
  organizationId String
  clientId       String?
  number         String
  status         EstimateStatus @default(DRAFT)
  issueDate      DateTime       @default(now())
  expiryDate     DateTime?
  subtotal       Decimal        @db.Decimal(12, 2) @default(0)
  taxRate        Decimal        @db.Decimal(5, 2) @default(0)
  taxAmount      Decimal        @db.Decimal(12, 2) @default(0)
  discount       Decimal        @db.Decimal(12, 2) @default(0)
  total          Decimal        @db.Decimal(12, 2) @default(0)
  currency       String         @default("USD")
  notes          String?        @db.Text
  terms          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items        EstimateItem[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@map("estimates")
}

enum EstimateStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  INVOICED
}

model EstimateItem {
  id          String  @id @default(cuid())
  estimateId  String
  description String
  quantity    Decimal @db.Decimal(10, 2) @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  taxable     Boolean @default(true)
  order       Int     @default(0)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_items")
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  invoiceId      String?
  clientId       String?
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD")
  method         PaymentMethod @default(OTHER)
  status         PaymentStatus @default(PENDING)
  reference      String?
  notes          String?
  paidAt         DateTime?
  stripePaymentIntentId String?
  stripeChargeId        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("payments")
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  SQUARE
  BANK_TRANSFER
  CASH
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

model RecurringBilling {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  name           String
  interval       String
  dayOfMonth     Int?
  nextBillingDate DateTime?
  isActive       Boolean  @default(true)
  templateData   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("recurring_billings")
}

// ============================================================
// PROJECTS & TASKS
// ============================================================

model Project {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String?
  name           String
  description    String?       @db.Text
  status         ProjectStatus @default(ACTIVE)
  color          String?
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  budget         Decimal?      @db.Decimal(12, 2)
  budgetType     String?
  hourlyRate     Decimal?      @db.Decimal(8, 2)
  isTemplate     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  members      ProjectMember[]
  tasks        Task[]
  timeEntries  TimeEntry[]
  files        File[]

  @@index([organizationId])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String
  userId    String
  role      String @default("member")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String?
  parentId       String?
  title          String
  description    String?      @db.Text
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  completedAt    DateTime?
  order          Int          @default(0)
  columnId       String?
  estimatedHours Decimal?     @db.Decimal(6, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       Task?            @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks     Task[]           @relation("TaskSubtasks")
  assignments  TaskAssignment[]
  timeEntries  TimeEntry[]
  comments     Comment[]
  tags         TaskTag[]
  files        File[]

  @@index([organizationId])
  @@index([projectId])
  @@map("tasks")
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TaskAssignment {
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_assignments")
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

model TimeEntry {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  taskId         String?
  projectId      String?
  description    String?
  startTime      DateTime
  endTime        DateTime?
  duration       Int?
  isBillable     Boolean  @default(true)
  hourlyRate     Decimal? @db.Decimal(8, 2)
  invoiced       Boolean  @default(false)
  invoiceItemId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("time_entries")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ============================================================
// SCHEDULING
// ============================================================

model Event {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  title          String
  description    String?  @db.Text
  location       String?
  videoUrl       String?
  startAt        DateTime
  endAt          DateTime
  allDay         Boolean  @default(false)
  isRecurring    Boolean  @default(false)
  recurringRule  String?
  googleEventId  String?
  outlookEventId String?
  bookingId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  attendees    EventAttendee[]

  @@index([organizationId])
  @@map("events")
}

model EventAttendee {
  id      String @id @default(cuid())
  eventId String
  email   String
  name    String?
  status  String @default("pending")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_attendees")
}

model BookingPage {
  id                  String   @id @default(cuid())
  organizationId      String
  slug                String
  name                String
  description         String?  @db.Text
  duration            Int      @default(60)
  bufferTime          Int      @default(15)
  isActive            Boolean  @default(true)
  availabilityRules   Json
  requireConfirmation Boolean  @default(false)
  collectPhone        Boolean  @default(false)
  collectNotes        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@unique([organizationId, slug])
  @@map("booking_pages")
}

model Booking {
  id            String        @id @default(cuid())
  bookingPageId String
  guestName     String
  guestEmail    String
  guestPhone    String?
  notes         String?       @db.Text
  status        BookingStatus @default(PENDING)
  startAt       DateTime
  endAt         DateTime
  videoUrl      String?
  reminderSentAt DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  bookingPage BookingPage @relation(fields: [bookingPageId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ============================================================
// COMMUNICATION
// ============================================================

model EmailAccount {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  name           String?
  provider       String
  accessToken    String?  @db.Text
  refreshToken   String?  @db.Text
  expiresAt      DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  threads      Thread[]

  @@map("email_accounts")
}

model Thread {
  id              String     @id @default(cuid())
  organizationId  String
  clientId        String?
  emailAccountId  String?
  subject         String?
  type            ThreadType @default(EMAIL)
  lastMessageAt   DateTime?
  isRead          Boolean    @default(false)
  isArchived      Boolean    @default(false)
  gmailThreadId   String?
  outlookThreadId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  emailAccount EmailAccount? @relation(fields: [emailAccountId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@index([organizationId])
  @@map("threads")
}

enum ThreadType {
  EMAIL
  INTERNAL
  SMS
}

model Message {
  id               String   @id @default(cuid())
  threadId         String
  senderId         String?
  from             String?
  to               String[]
  cc               String[]
  bcc              String[]
  body             String   @db.Text
  htmlBody         String?  @db.Text
  isRead           Boolean  @default(false)
  sentAt           DateTime @default(now())
  gmailMessageId   String?
  outlookMessageId String?

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User?  @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@map("messages")
}

// ============================================================
// DOCUMENTS & FILES
// ============================================================

model Document {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String?
  title          String
  content        Json?
  type           DocumentType @default(DOCUMENT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("documents")
}

enum DocumentType {
  DOCUMENT
  PROPOSAL
  SOP
  MEETING_NOTES
  OTHER
}

model File {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  projectId      String?
  taskId         String?
  name           String
  originalName   String
  mimeType       String
  size           Int
  storageKey     String
  url            String?
  uploadedBy     String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("files")
}

model Contract {
  id             String         @id @default(cuid())
  organizationId String
  clientId       String?
  title          String
  content        Json
  status         ContractStatus @default(DRAFT)
  sentAt         DateTime?
  signedAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  signers      ContractSigner[]

  @@index([organizationId])
  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_SIGNED
  SIGNED
  DECLINED
  EXPIRED
  VOID
}

model ContractSigner {
  id            String   @id @default(cuid())
  contractId    String
  name          String
  email         String
  order         Int      @default(0)
  signedAt      DateTime?
  ipAddress     String?
  signatureData String?  @db.Text

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_signers")
}

// ============================================================
// WEBHOOKS & INTEGRATIONS
// ============================================================

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  url            String
  secret         String
  events         String[]
  isActive       Boolean  @default(true)
  lastDeliveredAt DateTime?
  lastStatus      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id        String   @id @default(cuid())
  webhookId String
  event     String
  payload   Json
  status    Int?
  response  String?  @db.Text
  error     String?  @db.Text
  sentAt    DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}

model Integration {
  id             String              @id @default(cuid())
  organizationId String
  provider       IntegrationProvider
  status         IntegrationStatus   @default(DISCONNECTED)
  credentials    Json?
  settings       Json?
  connectedAt    DateTime?
  lastSyncAt     DateTime?
  error          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@map("integrations")
}

enum IntegrationProvider {
  GOOGLE_WORKSPACE
  MICROSOFT_365
  STRIPE
  PAYPAL
  SQUARE
  QUICKBOOKS
  XERO
  FRESHBOOKS
  CALENDLY
  ACUITY
  HUBSPOT
  SALESFORCE
  DOCUSIGN
  HELLOSIGN
  SLACK
  ZOOM
  TWILIO
  ZAPIER
  MAKE
  MEETUP
  EVENTBRITE
  FACEBOOK
  DISCORD
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

// ============================================================
// AI
// ============================================================

model AIConversation {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  context        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@map("ai_conversations")
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  toolCalls      Json?
  toolResults    Json?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}
